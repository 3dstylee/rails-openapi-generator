{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["status", "metadata"],
  "properties": {
    "status": { "type": "string", "enum": ["ok", "pending", "error"] },
    "metadata": {
      "type": "object",
      "properties": {
        "request_id": { "type": "string", "format": "uuid" },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
